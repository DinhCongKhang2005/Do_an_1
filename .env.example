# ============================================================
# DTM_Khong_debate — Environment Variables Template
# ============================================================
# Sao chép file này thành .env và điền giá trị thực tế.
# KHÔNG commit file .env lên git.
# ============================================================

# --- Lựa chọn LLM Provider ---
# "vertex_ai_express", "vertex_ai" hoặc "google_ai_studio"
LLM_PROVIDER=vertex_ai_express

# --- Google AI Studio (API Key) ---
# Lấy tại: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- Vertex AI Express / Agent Platform (API Key dạng chuỗi) ---
VERTEX_AI_API_KEY=your_vertex_ai_api_key_here

# --- Google Cloud / Vertex AI (nếu dùng Service Account) ---
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=secrets/gcp_key.json   # KHÔNG commit secrets/

# --- LLM Model ---
LLM_MODEL_NAME=gemini-3.5-flash
LLM_TEMPERATURE=0.0
LLM_DELAY_SECONDS=0.5

# --- Pipeline Settings ---
# Số ký tự tối đa ghi vào log lỗi
MAX_ERROR_TEXT_LENGTH=300
