        <mxCell id="v19" value="&lt;b&gt;Guideline&lt;/b&gt;&lt;br&gt;• environmental_filter_guideline.md&lt;br&gt;• label_guideline_5_labels.md&lt;br&gt;• adjudication_protocol.md&lt;br&gt;• guideline_identify_actor.md&lt;br&gt;• guideline_identify_domain.md&lt;br&gt;• scoring_rubric_MSDR.md" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=13;align=left;verticalAlign=top;spacing=10;fillColor=#F7FAFC;strokeColor=#CBD5E0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="2540" y="210" width="360" height="245" as="geometry" />
        </mxCell>
        <mxCell id="v20" value="&lt;b&gt;Config&lt;/b&gt;&lt;br&gt;• project_config.yaml&lt;br&gt;• labels.yaml&lt;br&gt;• scoring_config.yaml&lt;br&gt;• actor_domain_config.yaml&lt;br&gt;• env_filter_keywords.yaml&lt;br&gt;&lt;br&gt;&lt;b&gt;Prompt&lt;/b&gt;&lt;br&gt;• env filter prompt&lt;br&gt;• classify 5-label prompt" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=13;align=left;verticalAlign=top;spacing=10;fillColor=#F7FAFC;strokeColor=#CBD5E0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="2540" y="480" width="360" height="245" as="geometry" />
        </mxCell>
        <mxCell id="v21" value="&lt;b&gt;Nguyên tắc kiểm soát&lt;/b&gt;&lt;br&gt;1. Metric LLM tính trước adjudication.&lt;br&gt;2. Không dùng nhãn LLM thô làm nhãn cuối.&lt;br&gt;3. final_label là đầu vào duy nhất cho scoring.&lt;br&gt;4. Actor/domain phải được chuẩn hóa trước bước 10.&lt;br&gt;5. W_i = 1.0 nếu không có căn cứ điều chỉnh.&lt;br&gt;6. Mọi review cần có reason/note." style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=13;align=left;verticalAlign=top;spacing=10;fillColor=#F7FAFC;strokeColor=#CBD5E0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="2540" y="750" width="360" height="310" as="geometry" />
        </mxCell>
        <mxCell id="v22" value="&lt;b&gt;Công thức Impact Score&lt;/b&gt;&lt;br&gt;C_i = αM_i + βS_i + γD_i + δR_i&lt;br&gt;C_norm = (C_i - min)/(max - min)&lt;br&gt;ImpactScore_i = direction_i × W_i × C_norm&lt;br&gt;&lt;br&gt;direction_i:&lt;br&gt;+1: BENEFIT_*&lt;br&gt;-1: COST_* / CONSTRAINT" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=13;align=left;verticalAlign=top;spacing=10;fillColor=#F7FAFC;strokeColor=#CBD5E0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="2540" y="1090" width="360" height="230" as="geometry" />
        </mxCell>
        <mxCell id="v23" value="&lt;b&gt;Đầu ra cuối cùng&lt;/b&gt;&lt;br&gt;• scored_dataset.xlsx&lt;br&gt;• scoring_summary.xlsx&lt;br&gt;• final_impact_report.xlsx&lt;br&gt;• pipeline_summary_report.xlsx&lt;br&gt;• figures/*.png" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=13;align=left;verticalAlign=top;spacing=10;fillColor=#F7FAFC;strokeColor=#CBD5E0;arcSize=8;" vertex="1" parent="1">
